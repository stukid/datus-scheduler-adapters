# docker-compose reads this file automatically if named `.env` in this dir.
# Copy to `.env` and fill in the real password; `.env` is gitignored.
#
# Shell env overrides .env, so if you already export STARROCKS_PASSWORD for
# the agent-1 project, the compose file will pick it up without a .env file.

# Required — password for the seeded `starrocks_local` Airflow connection
# (user/host/port/database are pinned in docker-compose.yml).
STARROCKS_PASSWORD=
